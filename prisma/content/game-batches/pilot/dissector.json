        "tool": [
          { "en": "Linear equation", "zh": "线性方程" },
          { "en": "Successive percent changes", "zh": "连续百分比变化", "correct": true },
          { "en": "System of equations", "zh": "方程组" },
          { "en": "Ratio and proportion", "zh": "比例关系" }
        ],
        "cueEn": "Two markdowns in a row → multiply by 0.80, then by 0.85. Don't add 20% + 15%.",
        "cueZh": "两次连续降价 → 依次乘 0.80 再乘 0.85，不能把 20% 和 15% 直接相加。",
        "steps": [
          { "en": "Apply the first 20% markdown: 60 × 0.80", "zh": "先应用第一次 20% 降价：60 × 0.80" },
          { "en": "Apply the additional 15% off that new price: × 0.85", "zh": "再对新价格打 85 折：× 0.85" }
        ],
        "turns": 2,
        "workEn": "60 × 0.80 = 48\n48 × 0.85 = 40.80",
        "workZh": "60 × 0.80 = 48\n48 × 0.85 = 40.80",
        "answerEn": "$40.80",
        "answerZh": "$40.80"
      },
      "explanation": null,
      "words": []
    },
    {
