    {
      "gameType": "dissector",
      "domain": "math",
      "difficulty": 3,
      "payload": {
        "textEn": "A movie theater sells adult tickets for $a and child tickets for $c each (in terms of ticket count). One group buys 3 adult and 2 child tickets for a total of 54 tickets-equivalent value, satisfying 3a + 2c = 54. Another group buys 1 adult and 4 child tickets satisfying a + 4c = 48. What is the value of the adult ticket count a?",
        "textZh": "一家电影院卖出的门票中，3 张成人票加 2 张儿童票满足 3a + 2c = 54，1 张成人票加 4 张儿童票满足 a + 4c = 48（a、c 为票的数量代号）。求 a 的值。",
        "ask": [
          { "en": "the value of a", "zh": "a 的值", "correct": true },
          { "en": "the value of c", "zh": "c 的值" },
          { "en": "the sum a + c", "zh": "a + c 的和" },
          { "en": "the difference a − c", "zh": "a − c 的差" }
        ],
        "tool": [
          { "en": "Quadratic formula", "zh": "求根公式" },
          { "en": "Pythagorean theorem", "zh": "勾股定理" },
          { "en": "Percent change", "zh": "百分比变化" },
          { "en": "System of equations (substitution)", "zh": "方程组（代入法）", "correct": true }
        ],
        "cueEn": "Solve the second equation for a in terms of c, then substitute into the first equation.",
        "cueZh": "从第二个方程中把 a 用 c 表示，再代入第一个方程。",
        "steps": [
          { "en": "From a + 4c = 48, get a = 48 − 4c", "zh": "由 a + 4c = 48，得 a = 48 − 4c" },
          { "en": "Substitute into 3a + 2c = 54: 3(48 − 4c) + 2c = 54", "zh": "代入 3a + 2c = 54：3(48 − 4c) + 2c = 54" },
          { "en": "Solve for c, then back-substitute to find a", "zh": "解出 c，再回代求出 a" }
        ],
        "turns": 3,
        "workEn": "a = 48 - 4c\n3(48-4c) + 2c = 54\n144 - 12c + 2c = 54\n144 - 10c = 54\nc = 9\na = 48 - 4(9) = 12",
        "workZh": "a = 48 - 4c\n3(48-4c) + 2c = 54\n144 - 12c + 2c = 54\n144 - 10c = 54\nc = 9\na = 48 - 4(9) = 12",
        "answerEn": "a = 12",
        "answerZh": "a = 12"
      },
      "explanation": null,
      "words": []
    },
