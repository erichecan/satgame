generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Word {
  id           String      @id @default(cuid())
  word         String      @unique
  partOfSpeech String?
  definitionEn String
  definitionCn String?
  exampleEn    String?
  difficulty   Int         @default(1)
  tier         String      @default("sat_core") // "foundation" | "sat_core"
  rank         Int         @default(9999) // order within tier for daily new-word selection
  synonymGroup String? // optional key linking words for discrimination display
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  vocabNotes   VocabNote[]
}

// 5 个游戏的题目内容统一存储，payload 按 gameType 存放各自结构化数据
model GameItem {
  id          String   @id @default(cuid())
  gameType    String // clusters | closer | read_the_green | gate_run | dissector
  domain      String // craft_structure | words_in_context | info_ideas | expression_conventions | math
  difficulty  Int      @default(1)
  payload     Json
  wordIds     String[] @default([]) // 关联 Word.id；空数组表示与具体单词无关（如 Dissector、Gate Run 标点题）
  explanation String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([gameType, isActive])
}

model Progress {
  id                 String    @id @default(cuid())
  gameType           String
  itemId             String?
  skill              String
  result             String // correct | incorrect
  attempts           Int       @default(1)
  masteryScore       Float     @default(0)
  consecutiveCorrect Int       @default(0)
  nextReview         DateTime?
  errorTag           String? // 选错时掉进的陷阱类型(trapType),用于错误 DNA 分析
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([skill, nextReview])
}

model VocabNote {
  id           String    @id @default(cuid())
  wordId       String
  word         Word      @relation(fields: [wordId], references: [id])
  addedFrom    String // wrong | asked_hint | gave_up | manual
  sourceGame   String?
  masteryLevel Int       @default(0) // 0=新 1=学习中 2=已掌握
  reviewCount  Int       @default(0)
  nextReview   DateTime?
  createdAt    DateTime  @default(now())

  @@index([nextReview])
}

// 单用户应用，无多用户体系，统计信息为单例行
model UserStats {
  id             String    @id @default("singleton")
  xp             Int       @default(0)
  streak         Int       @default(0)
  lastActiveDate DateTime?
  updatedAt      DateTime  @updatedAt
}

model Badge {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  earnedAt    DateTime @default(now())
}

// 每日测验题库：SAT 短文题结构，独立于 GameItem（生命周期和复用逻辑不同）
model QuizItem {
  id          String   @id @default(cuid())
  passage     String
  question    String
  options     Json // [{ t: string, correct?: boolean }], 四选一
  wordIds     String[] // 关联 Word.id，用于和当天 50 词做交集匹配
  domain      String // craft_structure | words_in_context | info_ideas | expression_conventions
  difficulty  Int      @default(2)
  explanation String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([isActive])
}

// 每日任务快照：一天一行，支持中途退出继续；三项（词/题/游戏）齐了才算打卡完成
model DailyAssignment {
  id          String    @id @default(cuid())
  date        String    @unique // "YYYY-MM-DD"，服务器本地日期
  wordIds     String[]
  quizItemIds String[]
  wordsViewed String[]  @default([])
  quizAnswers Json      @default("{}") // { [quizItemId]: "correct" | "incorrect" }
  gamesPlayed String[]  @default([])
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}
