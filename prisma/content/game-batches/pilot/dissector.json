    {
      "gameType": "dissector",
      "domain": "math",
      "difficulty": 2,
      "payload": {
        "textEn": "Solve for x: 3(x − 2) + 5 = 2x + 7.",
        "textZh": "求解 x：3(x − 2) + 5 = 2x + 7。",
        "ask": [
          { "en": "the value of x", "zh": "x 的值", "correct": true },
          { "en": "the value of 2x + 7", "zh": "2x + 7 的值" },
          { "en": "whether the equation has no solution", "zh": "该方程是否无解" },
          { "en": "the slope of the equation", "zh": "该方程的斜率" }
        ],
        "tool": [
          { "en": "Linear equation (distribute and isolate x)", "zh": "线性方程（先展开再解出 x）", "correct": true },
          { "en": "System of equations", "zh": "方程组" },
          { "en": "Quadratic formula", "zh": "求根公式" },
          { "en": "Ratio and proportion", "zh": "比例关系" }
        ],
        "cueEn": "Distribute the 3 first, then collect x-terms on one side and constants on the other.",
        "cueZh": "先展开括号里的 3，再把含 x 的项移到一边、常数移到另一边。",
        "steps": [
          { "en": "Distribute: 3x − 6 + 5 = 2x + 7", "zh": "展开：3x − 6 + 5 = 2x + 7" },
          { "en": "Simplify left side: 3x − 1 = 2x + 7", "zh": "化简左边：3x − 1 = 2x + 7" },
          { "en": "Subtract 2x and add 1 to both sides: x = 8", "zh": "两边减 2x 加 1：x = 8" }
        ],
        "turns": 3,
        "workEn": "3(x-2)+5 = 2x+7\n3x-6+5 = 2x+7\n3x-1 = 2x+7\nx = 8",
        "workZh": "3(x-2)+5 = 2x+7\n3x-6+5 = 2x+7\n3x-1 = 2x+7\nx = 8",
        "answerEn": "x = 8",
        "answerZh": "x = 8"
      },
      "explanation": null,
      "words": []
    },
    {
      "gameType": "dissector",
      "domain": "math",
      "difficulty": 2,
      "payload": {
        "textEn": "The sum of two numbers is 11 and their difference is 1. What is the larger number?",
        "textZh": "两个数的和是 11，差是 1。较大的数是多少？",
        "ask": [
          { "en": "the smaller number", "zh": "较小的数" },
          { "en": "the larger number", "zh": "较大的数", "correct": true },
          { "en": "the product of the two numbers", "zh": "两数之积" },
          { "en": "the average of the two numbers", "zh": "两数的平均值" }
        ],
        "tool": [
          { "en": "Quadratic formula", "zh": "求根公式" },
          { "en": "System of equations (elimination)", "zh": "方程组（消元法）", "correct": true },
          { "en": "Percent change", "zh": "百分比变化" },
          { "en": "Pythagorean theorem", "zh": "勾股定理" }
        ],
        "cueEn": "Let x and y be the numbers: x + y = 11, x − y = 1. Adding the equations eliminates y.",
        "cueZh": "设两数为 x 和 y：x + y = 11，x − y = 1。两式相加即可消去 y。",
        "steps": [
          { "en": "Write the two equations: x + y = 11 and x − y = 1", "zh": "写出两个方程：x + y = 11 和 x − y = 1" },
          { "en": "Add the equations to eliminate y: 2x = 12, so x = 6", "zh": "两式相加消去 y：2x = 12，得 x = 6" },
          { "en": "Substitute back to find y = 5", "zh": "代回求出 y = 5" }
        ],
        "turns": 3,
        "workEn": "x+y=11\nx-y=1\n2x=12 -> x=6\ny=11-6=5",
        "workZh": "x+y=11\nx-y=1\n2x=12 -> x=6\ny=11-6=5",
        "answerEn": "6",
        "answerZh": "6"
      },
      "explanation": null,
      "words": []
    },
    {
      "gameType": "dissector",
      "domain": "math",
