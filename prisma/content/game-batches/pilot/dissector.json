        "textZh": "在地图上，1 英寸代表 25 英里。如果两个城市在地图上相距 3.5 英寸，它们的实际距离是多少？",
        "ask": [
          { "en": "the map scale itself", "zh": "地图比例尺本身" },
          { "en": "the actual distance between the cities", "zh": "两城市的实际距离", "correct": true },
          { "en": "the map distance in inches", "zh": "地图上的距离（英寸）" },
          { "en": "the number of cities", "zh": "城市的数量" }
        ],
        "tool": [
          { "en": "Quadratic formula", "zh": "求根公式" },
          { "en": "System of equations", "zh": "方程组" },
          { "en": "Ratio and proportion", "zh": "比例关系（设置比例式）", "correct": true },
          { "en": "Pythagorean theorem", "zh": "勾股定理" }
        ],
        "cueEn": "Set up a proportion: 1 inch / 25 miles = 3.5 inches / x miles.",
        "cueZh": "列出比例式：1 英寸 / 25 英里 = 3.5 英寸 / x 英里。",
        "steps": [
          { "en": "Set up the proportion 1/25 = 3.5/x", "zh": "列出比例式 1/25 = 3.5/x" },
          { "en": "Cross-multiply and solve for x", "zh": "交叉相乘并解出 x" }
        ],
        "turns": 2,
        "workEn": "1/25 = 3.5/x\nx = 3.5 × 25 = 87.5",
        "workZh": "1/25 = 3.5/x\nx = 3.5 × 25 = 87.5",
        "answerEn": "87.5 miles",
        "answerZh": "87.5 英里"
      },
      "explanation": null,
      "words": []
    },
